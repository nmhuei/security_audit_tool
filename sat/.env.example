# ══════════════════════════════════════════════════════════════════
#  Security Audit Tool – API Keys
#  Ném key vào đây rồi chạy: source .env && python3 main.py scan
#  KHÔNG commit file này lên git!
# ══════════════════════════════════════════════════════════════════

# ── Anthropic ──────────────────────────────────────────────────────
# Format: sk-ant-api03-[86 ký tự]
# Lấy tại: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── OpenRouter ─────────────────────────────────────────────────────
# Format: sk-or-v1-[64 ký tự hex]
# Lấy tại: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4   # đổi model tại đây

# ── OpenAI ─────────────────────────────────────────────────────────
# Format: sk-proj-[48 ký tự]
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini ──────────────────────────────────────────────────
# Format: AIza[35 ký tự]
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Groq (nhanh + free tier) ───────────────────────────────────────
# Format: gsk_[52 ký tự]
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── DeepSeek ───────────────────────────────────────────────────────
# Format: sk-[32 ký tự hex]
# Lấy tại: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Mistral ────────────────────────────────────────────────────────
# Format: [32 ký tự alphanum]
# Lấy tại: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ── Together AI ────────────────────────────────────────────────────
# Format: [64 ký tự hex]
# Lấy tại: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# ── Cohere ─────────────────────────────────────────────────────────
# Format: [40 ký tự alphanum]
# Lấy tại: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
COHERE_MODEL=command-r-plus-08-2024

# ── Ollama (local) ─────────────────────────────────────────────────
# Không cần key – chỉ cần ollama đang chạy: ollama serve
# Đổi host nếu chạy trên máy khác
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LM Studio (local) ──────────────────────────────────────────────
# Không cần key – bật Local Server trong LM Studio
LMSTUDIO_HOST=http://localhost:1234
LMSTUDIO_MODEL=local-model
